{
  "name": "aminet",
  "version": "0.1.1",
  "description": "CLI and GitHub Action for npm supply chain security reviews",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gorira-tatsu/aminet.git"
  },
  "homepage": "https://github.com/gorira-tatsu/aminet",
  "bugs": {
    "url": "https://github.com/gorira-tatsu/aminet/issues"
  },
  "packageManager": "pnpm@10.28.0",
  "keywords": [
    "security",
    "supply-chain",
    "npm",
    "sbom",
    "license",
    "dependencies",
    "github-action",
    "cli"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md"
  ],
  "type": "module",
  "bin": {
    "aminet": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm build",
    "prepare": "pnpm build",
    "start": "node ./dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "INTEGRATION_TEST=1 vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "ora": "^8.2.0",
    "semver": "^7.7.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.0",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
